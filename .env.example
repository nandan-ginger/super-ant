# ============================================
# Ginger LiveChat AI Copilot — Environment
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-exp-03-07

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ginger_copilot
PG_USER=ginger
PG_PASSWORD=ginger_dev
# Or use a full connection string (overrides individual settings):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- CORS ---
# Comma-separated list of allowed origins for the widget
# Use * for local dev or specify exact domains in production
CORS_ORIGIN=*

# --- Session ---
# Minutes before an idle session is purged from memory
SESSION_TTL_MINUTES=30

# --- RAG ---
# Token thresholds for routing strategy
RAG_DIRECT_LIMIT=5000
RAG_CHUNK_LIMIT=50000
RAG_TOP_K=5

# ============================================
# Product / Admin Settings
# ============================================

# --- Admin Auth (JWT) ---
# Secret key for signing JWT tokens — use a long random string in production!
JWT_SECRET=changeme_jwt_secret_use_a_long_random_string_here
# Token expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRY=7d

# --- Widget Embed Script ---
# Base URL of this backend server — used in the auto-generated widget embed script
SERVER_BASE_URL=http://localhost:3001

# --- Initial SuperAdmin Credentials ---
# These are only used ONCE on first startup to seed the superadmin account.
# Change these BEFORE deploying to production!
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=changeme_superadmin_password_CHANGE_THIS
